[Unit]
Description=JC1 Edge AI Gateway (OpenAI-compatible API)
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/lucineer/.openclaw/workspace/tools/edge-gateway.py --port 11435 --host 127.0.0.1
Restart=on-failure
RestartSec=5
WorkingDirectory=/home/lucineer/.openclaw/workspace/tools
Environment=PATH=/home/lucineer/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/lucineer

# Security
NoNewPrivileges=yes
ProtectSystem=full
ReadWritePaths=/home/lucineer/.openclaw/workspace

[Install]
WantedBy=default.target
